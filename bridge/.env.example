# Minecraft connection
BOT_CONNECT_ENABLED=true
MC_HOST=127.0.0.1
MC_PORT=25565
MC_VERSION=1.21.1
BOT_USERNAME=CodexBot

# Use offline for local servers with online-mode=false.
# Use microsoft for normal authenticated servers.
BOT_AUTH=offline

# Optional reconnect behavior
BOT_RECONNECT=true
BOT_RECONNECT_DELAY_MS=5000

# Command access
# Empty BOT_OWNERS means everyone can control the bot. For a real server, set comma-separated names.
BOT_OWNERS=
BOT_COMMAND_PREFIX=!

# Movement and chat safety
BOT_DEFAULT_FOLLOW_DISTANCE=3
BOT_MAX_CHAT_LENGTH=240
BOT_CHAT_DELAY_MS=1100
BOT_ALLOW_DIGGING=false
BOT_ACCEPT_RESOURCE_PACKS=false
BOT_MOVEMENT_ENABLED=true
BOT_DEFAULT_SCAN_RADIUS=24
BOT_GUARD_RADIUS=24
BOT_GUARD_SCAN_INTERVAL_MS=3000
BOT_GUARD_REPORT_COOLDOWN_MS=12000
BOT_PATROL_GOAL_RANGE=2
BOT_MEMORY_FILE=data/bot-memory.json

# Optional AI controller. Disabled by default; command mode works without this.
AI_ENABLED=false
# openai = direct Responses API. codex-cli = local Codex CLI non-interactive exec.
AI_PROVIDER=openai
AI_LISTEN_MODE=mention
AI_MODEL=gpt-5.2
AI_COOLDOWN_MS=3500
AI_MAX_OUTPUT_TOKENS=600
OPENAI_API_KEY=

# Used only when AI_PROVIDER=codex-cli.
CODEX_CLI_COMMAND=codex
# Verified after updating @openai/codex to 0.125.0.
CODEX_MODEL=gpt-5.5
CODEX_TIMEOUT_MS=60000

# HTTP bridge for a future NeoForge companion mod.
# Use BOT_CONNECT_ENABLED=false when running bridge-only against a NeoForge server that rejects Mineflayer.
BRIDGE_ENABLED=false
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787
BRIDGE_TOKEN=
BRIDGE_MAX_BODY_BYTES=1048576
BRIDGE_HISTORY_LIMIT=100
